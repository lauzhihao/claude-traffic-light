# 复制为 .env 填真实值(.env 已被 .gitignore,不进仓库)

# --- APNs 凭据(与 iOS App 同一 Apple 账号)---
RELAY_APNS_KEY_ID=6V2GZFJ8UQ
RELAY_APNS_TEAM_ID=Z3LULFMC72
RELAY_APNS_BUNDLE_ID=com.liuzhihao.claudetrafficlight
# production=App Store/TestFlight 装的 App;sandbox=Xcode debug 直接装真机的 App
RELAY_APNS_ENV=sandbox
# 宿主机上 .p8 的绝对路径(compose 会只读挂到容器 /secrets/apns.p8)
RELAY_APNS_P8_HOST=/root/claude-light/AuthKey_6V2GZFJ8UQ.p8

# --- 管理员密钥(建/删用户用;务必随机)---
RELAY_ADMIN_SECRET=CHANGE_ME_openssl_rand_hex_32

# --- 限频(可选,留默认即可)---
RELAY_RATE_WINDOW_S=60
RELAY_RATE_MAX=120
