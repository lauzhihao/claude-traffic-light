# 复制为 .env 填真实值(.env 已被 .gitignore,不进仓库)。占位符全部要替换。

# --- APNs 凭据(与 iOS App 同一 Apple 账号;在 Apple Developer 后台取)---
RELAY_APNS_KEY_ID=XXXXXXXXXX
RELAY_APNS_TEAM_ID=XXXXXXXXXX
RELAY_APNS_BUNDLE_ID=com.example.yourapp
# production=App Store/TestFlight 装的 App;sandbox=Xcode debug 直接装真机的 App。
# ⚠️ 必须和设备 token 的来源一致,否则 APNs 全返 400,推送全失败(但本中继只在 410
#    才剔除 token,不会因 env 配错而误清设备)。
RELAY_APNS_ENV=production
# 宿主机上 .p8 的绝对路径(compose 只读挂到容器 /secrets/apns.p8)
RELAY_APNS_P8_HOST=/path/to/AuthKey_XXXXXXXXXX.p8

# --- 管理员密钥(建/删用户用)---
# 必填且要够强:openssl rand -hex 32。含 "CHANGE_ME" 或短于 16 位会启动失败(fail-fast)。
# 留空则 admin 接口整体禁用(安全)。
RELAY_ADMIN_SECRET=

# --- 限频 / 配额(可选,留默认即可)---
RELAY_RATE_WINDOW_S=60
RELAY_RATE_MAX=120
RELAY_DEVICE_LIMIT=10
