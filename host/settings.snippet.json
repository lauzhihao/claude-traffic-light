{
  "_comment": "把 hooks 部分合并到你的 ~/.claude/settings.json。把 LIGHT_SH 改成 light.sh 的绝对路径（用 realpath 拿）。",

  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "/ABSOLUTE/PATH/TO/host/light.sh R" }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "/ABSOLUTE/PATH/TO/host/light.sh Y" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "/ABSOLUTE/PATH/TO/host/light.sh G" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "/ABSOLUTE/PATH/TO/host/light.sh PRE" }
        ]
      }
    ]
  }
}
